&control
    calculation = 'scf'
    prefix      = 'nbse2'
    outdir      = './out'
    pseudo_dir  = '../../pseudos'
    verbosity   = 'high'
/
&system
    ibrav           = 0
    nat             = 3
    ntyp            = 2
    ecutwfc         = 60.0
    ecutrho         = 480.0
    assume_isolated = '2D'
    occupations     = 'smearing'
    smearing        = 'mv'
    degauss         = 0.01
/
&electrons
    conv_thr    = 1.0d-16
    mixing_beta = 0.7
/
