&control
    calculation = 'scf'
    prefix      = 'graphene'
    outdir      = './out'
    pseudo_dir  = '../../pseudos'
    verbosity   = 'high'
/
&system
    ibrav = 0
    nat = 2
    ntyp = 1
    ecutwfc = 50.0
    ecutrho = 400.0
    assume_isolated = '2D'
    occupations = 'smearing'
    smearing = 'mv'
    degauss = 0.01
/
&electrons
    conv_thr = 1.0d-20
    mixing_beta = 0.7
/
ATOMIC_SPECIES
  C 12.011 C.pbe-n-kjpaw_psl.1.0.0.UPF
CELL_PARAMETERS angstrom
   2.467137   0.000000   0.000000
  -1.233568   2.136488   0.000000
   0.000000   0.000000  20.000000
ATOMIC_POSITIONS crystal
  C 0.000000000 0.000000000 0.0
  C 0.333333333 0.666666667 0.0
K_POINTS automatic
  12 12 1 0 0 0
