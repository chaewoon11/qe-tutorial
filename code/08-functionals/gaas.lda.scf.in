&control
    calculation = 'scf'
    prefix      = 'gaas_lda'
    outdir      = './out'
    pseudo_dir  = '../pseudos'
    verbosity   = 'high'
/
&system
    ibrav = 0
    celldm(1) = 10.6829
    nat = 2
    ntyp = 2
    ecutwfc = 50.0
    ecutrho = 400.0
    occupations = 'fixed'
/
&electrons
    conv_thr = 1.0d-10
    mixing_beta = 0.7
/
ATOMIC_SPECIES
  Ga  69.723   Ga.pz-dn-kjpaw_psl.0.2.UPF
  As  74.9216  As.pz-n-kjpaw_psl.0.2.UPF
CELL_PARAMETERS alat
  -0.50   0.00   0.50
   0.00   0.50   0.50
  -0.50   0.50   0.00
ATOMIC_POSITIONS alat
  Ga  0.00  0.00  0.00
  As  0.25  0.25  0.25
K_POINTS automatic
  8 8 8 0 0 0
