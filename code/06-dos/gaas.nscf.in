&control
 calculation='nscf', prefix='gaas', outdir='./out', pseudo_dir='../pseudos', verbosity='high'
/
&system
 ibrav=0, celldm(1)=10.6829, nat=2, ntyp=2, ecutwfc=50.0, ecutrho=400.0, occupations='tetrahedra', nbnd=24
/
&electrons
