&control
    calculation   = 'scf'
    prefix        = 'al'
    outdir        = './out'
    pseudo_dir    = '../pseudos'
    verbosity     = 'high'
/
&system
    ibrav         = 0
    celldm(1)     = 7.6533         ! fcc Al, a = 4.05 Å
    nat           = 1
    ntyp          = 1
    ecutwfc       = 40.0
    ecutrho       = 320.0
    occupations   = 'smearing'     ! metal: smooth the Fermi-surface step
    smearing      = 'mv'           ! Marzari–Vanderbilt cold smearing
    degauss       = 0.02           ! smearing width (Ry)
/
&electrons
    conv_thr      = 1.0d-10
    mixing_beta   = 0.7
/
ATOMIC_SPECIES
  Al  26.9815  Al.pbe-n-kjpaw_psl.1.0.0.UPF

CELL_PARAMETERS alat
  -0.50   0.00   0.50
   0.00   0.50   0.50
  -0.50   0.50   0.00

ATOMIC_POSITIONS alat
  Al  0.00  0.00  0.00

K_POINTS automatic
  12 12 12 0 0 0
