&control
    calculation   = 'scf'
    prefix        = 'si'
    outdir        = './out'
    pseudo_dir    = '../../setup/pseudos'
    verbosity     = 'high'
/
&system
    ibrav         = 0
    celldm(1)     = 10.26
    nat           = 2
    ntyp          = 1
    ecutwfc       = 40.0
    occupations   = 'fixed'
/
&electrons
    conv_thr      = 1.0d-8
    mixing_beta   = 0.7
/
ATOMIC_SPECIES
  Si  28.0855  Si_ONCV_PBE-1.1.upf

CELL_PARAMETERS alat
  -0.50   0.00   0.50
   0.00   0.50   0.50
  -0.50   0.50   0.00

ATOMIC_POSITIONS alat
  Si  0.00  0.00  0.00
  Si  0.25  0.25  0.25

K_POINTS automatic
  6 6 6 0 0 0
